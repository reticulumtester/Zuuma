<section id="bag-features" data-features-scene="bag">
  <div class="features-stage" data-bag-dest="bag">
    <div class="features-stage-image" data-features-fallback-image>
      <img src="{{ 'bag-02.jpg' | asset_url }}" alt="" loading="lazy">
    </div>
    <svg class="features-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
      {% for block in section.blocks %}
        {%- assign x = block.settings.x | default: 50 -%}
        {%- assign y = block.settings.y | default: 50 -%}
        <line
          class="callout-line"
          data-callout-line="{{ forloop.index }}"
          x1="{{ x }}" y1="{{ y }}"
          x2="{{ x }}" y2="{{ y }}"
          stroke="rgba(79,205,196,0.8)"
          stroke-width="0.15"
          stroke-linecap="round"
          vector-effect="non-scaling-stroke"
          pathLength="1"
        />
      {% endfor %}
    </svg>
    {% for block in section.blocks %}
      {%- assign x = block.settings.x | default: 50 -%}
      {%- assign y = block.settings.y | default: 50 -%}
      <span class="callout-dot"
            data-callout-dot="{{ forloop.index }}"
            style="left: {{ x }}%; top: {{ y }}%"></span>
    {% endfor %}
  </div>

  <div class="features-list">
    <div class="features-head reveal">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.headline }}<em>{{ section.settings.headline_em }}</em></h2>
    </div>
    {% for block in section.blocks %}
      <div class="feature-item reveal {% cycle 'd0','d1','d2','d3' %}"
           data-feature-index="{{ forloop.index }}">
        <span class="num">0{{ forloop.index }}</span>
        <div>
          <p class="label">{{ block.settings.label }}</p>
          <p class="value">{{ block.settings.value }}</p>
          <p class="desc">{{ block.settings.description }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Bag — Features",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Anatomy of the bag" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Built to" },
    { "type": "text", "id": "headline_em", "label": "Headline italic", "default": "carry it all." }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "Feature callout",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Volume" },
        { "type": "text", "id": "value", "label": "Value", "default": "30 litres" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "range", "id": "x", "label": "Dot X (% across image)", "min": 0, "max": 100, "step": 1, "default": 50, "unit": "%" },
        { "type": "range", "id": "y", "label": "Dot Y (% down image)", "min": 0, "max": 100, "step": 1, "default": 50, "unit": "%" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Bag Features", "category": "Zuuma" }
  ]
}
{% endschema %}

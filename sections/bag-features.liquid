<section id="bag-features" data-feature-scene>
  <div class="feature-scene-head reveal">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="section-h">{{ section.settings.headline }}<em>{{ section.settings.headline_em }}</em></h2>
    {% if section.settings.subline != blank %}
      <p class="feature-scene-sub reveal d1">{{ section.settings.subline }}</p>
    {% endif %}
  </div>

  <div class="feature-scene">
    <div class="feature-scene-visual">
      <div class="feature-visual-stack">
        {% for block in section.blocks %}
          <figure class="feature-visual {% if forloop.first %}is-active{% endif %}"
                  data-feature-visual="{{ forloop.index }}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1600 | image_tag:
                 loading: 'lazy',
                 sizes: '(min-width: 960px) 55vw, 100vw',
                 widths: '600,900,1200,1600',
                 alt: block.settings.label }}
            {% else %}
              {%- assign fallback = forloop.index | plus: 1 -%}
              {%- if fallback > 5 -%}{%- assign fallback = 2 -%}{%- endif -%}
              <img src="{{ 'bag-0' | append: fallback | append: '.jpg' | asset_url }}"
                   alt="{{ block.settings.label }}" loading="lazy">
            {% endif %}
            <figcaption class="feature-visual-caption">
              <span class="feature-visual-num">0{{ forloop.index }}</span>
              <span class="feature-visual-label">{{ block.settings.label }}</span>
            </figcaption>
          </figure>
        {% endfor %}
      </div>

      <div class="feature-progress" aria-hidden="true">
        {% for block in section.blocks %}
          <span class="feature-progress-tick" data-feature-tick="{{ forloop.index }}"></span>
        {% endfor %}
      </div>
    </div>

    <div class="feature-scene-narrative">
      {% for block in section.blocks %}
        <article class="feature-card {% if forloop.first %}is-active{% endif %}"
                 data-feature-card="{{ forloop.index }}">
          <header class="feature-card-index">
            <span class="feature-card-num">0{{ forloop.index }}</span>
            <span class="feature-card-total">/ 0{{ section.blocks.size }}</span>
          </header>
          <p class="feature-card-label">{{ block.settings.label }}</p>
          <h3 class="feature-card-value">{{ block.settings.value }}</h3>
          <p class="feature-card-desc">{{ block.settings.description }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bag — Features",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Anatomy of the bag" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Built to" },
    { "type": "text", "id": "headline_em", "label": "Headline italic", "default": "carry it all." },
    { "type": "textarea", "id": "subline", "label": "Subline",
      "default": "One bag, four details that matter. Every choice earns its place." }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Detail image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Volume" },
        { "type": "text", "id": "value", "label": "Value", "default": "30 litres" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    { "name": "Bag Features", "category": "Zuuma" }
  ]
}
{% endschema %}

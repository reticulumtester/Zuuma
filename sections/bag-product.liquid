{%- assign product = section.settings.product -%}
<section id="bag-product" data-zuuma-section="bag-product">
  <div class="product-grid">
    <div class="product-image-col reveal">
      <div class="product-main-img" data-parallax-image>
        {% if section.settings.product_image != blank %}
          {{ section.settings.product_image | image_url: width: 1400 | image_tag:
             sizes: '(min-width: 960px) 50vw, 100vw',
             widths: '600,900,1200,1400',
             alt: 'Zuuma Bag' }}
        {% elsif product and product.featured_image %}
          {{ product.featured_image | image_url: width: 1400 | image_tag:
             sizes: '(min-width: 960px) 50vw, 100vw',
             widths: '600,900,1200,1400',
             alt: product.title }}
        {% else %}
          <img src="{{ 'bag-05.jpg' | asset_url }}" alt="Zuuma Bag" loading="lazy">
        {% endif %}
      </div>
      <figcaption class="product-image-foot">
        <span>{{ section.settings.image_caption }}</span>
      </figcaption>
    </div>

    <div class="product-info-col">
      <p class="p-label reveal">{{ section.settings.eyebrow }}</p>
      <h2 class="p-title reveal d1">{{ section.settings.title }}<em>{{ section.settings.title_em }}</em></h2>

      <div class="p-accent reveal d2"></div>

      <p class="p-copy reveal d2">{{ section.settings.copy }}</p>

      {% if section.settings.spec_line != blank %}
        <p class="p-spec-line reveal d3">{{ section.settings.spec_line }}</p>
      {% endif %}

      <div class="p-cta reveal d4">
        {% if product %}
          <form data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                action="/cart/add" method="post" enctype="multipart/form-data">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <button type="submit" class="btn-cart"
                    {% unless product.available %}disabled{% endunless %}>
              {% if product.available %}
                <span>{{ 'products.product.add_to_cart' | t }}</span>
                <span class="btn-cart-price">{{ product.price | money }}</span>
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>
          </form>
        {% else %}
          <a class="btn-cart" href="{{ section.settings.cta_link | default: routes.cart_url }}">
            <span>{{ section.settings.cta_label }}</span>
            {% if section.settings.price_display != blank %}
              <span class="btn-cart-price">{{ section.settings.price_display }}</span>
            {% endif %}
          </a>
        {% endif %}
        <p class="p-note">{{ section.settings.note }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bag — Product",
  "settings": [
    { "type": "product", "id": "product", "label": "Product", "info": "Link a real Shopify product to enable Add to Cart." },
    { "type": "image_picker", "id": "product_image", "label": "Product image override" },
    { "type": "text", "id": "image_caption", "label": "Image caption", "default": "No. 001 · Zuuma Black" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Bag · Zuuma" },
    { "type": "text", "id": "title", "label": "Title", "default": "Zuuma" },
    { "type": "text", "id": "title_em", "label": "Title italic", "default": "Bag" },
    { "type": "textarea", "id": "copy", "label": "Descriptive copy" },
    { "type": "text", "id": "spec_line", "label": "Inline spec line", "default": "30 L · 10 kg max · 400 g · 52 × 60 cm" },
    { "type": "text", "id": "price_display", "label": "Fallback price (e.g. €90)", "default": "" },
    { "type": "text", "id": "note", "label": "Note", "default": "Free shipping · Numbered · Washable to 30°" },
    { "type": "text", "id": "cta_label", "label": "Fallback CTA label", "default": "Add to Cart" },
    { "type": "url", "id": "cta_link", "label": "Fallback CTA link" }
  ],
  "presets": [
    { "name": "Bag — Product", "category": "Zuuma" }
  ]
}
{% endschema %}

{%- assign items = section.settings.items | split: '·' -%}
<div class="marquee-strip" id="marquee-{{ section.id }}">
  <div class="marquee-track">
    {% for item in items %}
      <span class="m-item">{{ item | strip }}</span>
      {% unless forloop.last %}
        <span class="m-item" aria-hidden="true"><span class="m-dot">✦</span></span>
      {% endunless %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "items",
      "label": "Items (separate with ·)",
      "default": "Made in Berlin · Handmade & Numbered · Ships Worldwide"
    }
  ],
  "presets": [
    { "name": "Announcement bar", "category": "Zuuma" }
  ]
}
{% endschema %}

{%- assign items = section.settings.items | split: '·' -%}
<div class="marquee-strip" id="marquee-{{ section.id }}">
  <div class="marquee-track">
    {% for i in (1..2) %}
      {% for item in items %}
        <span class="m-item">{{ item | strip }}</span>
        <span class="m-item" aria-hidden="true"><span class="m-dot">✦</span></span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Marquee / Announcement",
  "settings": [
    {
      "type": "text",
      "id": "items",
      "label": "Items (separate with ·)",
      "default": "Made in Berlin · Handmade & Numbered · 100% Cotton Canvas · Ships Worldwide · Free Returns in Europe"
    }
  ],
  "presets": [
    { "name": "Marquee / Announcement", "category": "Zuuma" }
  ]
}
{% endschema %}

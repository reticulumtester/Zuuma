{%- assign items = section.settings.items | split: '·' -%}
<div class="marquee-strip" id="marquee-{{ section.id }}">
  <div class="marquee-track">
    {% for i in (1..2) %}
      {% for item in items %}
        <span class="m-item">{{ item | strip }}</span>
        <span class="m-item"><span class="m-dot">✦</span></span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "text",
      "id": "items",
      "label": "Items (separate with ·)",
      "default": "The bag you stop noticing · Handmade in Berlin · Numbered by hand · One bag, every day"
    }
  ],
  "presets": [
    { "name": "Marquee", "category": "Zuuma" }
  ]
}
{% endschema %}

<section id="prints" data-zuuma-section="prints" class="studio-section">
  <div class="prints-head reveal">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.title }}<br><em>{{ section.settings.title_em }}</em></h2>
    {% if section.settings.standfirst != blank %}
      <p class="studio-standfirst reveal d1">{{ section.settings.standfirst }}</p>
    {% endif %}
    {% if section.settings.link_label != blank %}
      <a class="studio-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>
    {% endif %}
  </div>

  <div class="prints-grid">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'print' %}
          <a class="print-card reveal {% cycle 'd0','d1' %}" href="{{ block.settings.link }}">
            <div class="print-card-img">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1000 | image_tag:
                   sizes: '(min-width: 960px) 50vw, 100vw',
                   widths: '600,900,1200',
                   alt: block.settings.name,
                   loading: 'lazy' }}
              {% else %}
                <div class="print-ph">
                  <svg width="30" height="30" viewBox="0 0 30 30" fill="none">
                    <rect x="1" y="1" width="28" height="28" stroke="currentColor" stroke-width="0.75"/>
                    {% if forloop.index == 1 %}
                      <line x1="1" y1="1" x2="29" y2="29" stroke="currentColor" stroke-width="0.5"/>
                    {% else %}
                      <circle cx="15" cy="15" r="10" stroke="currentColor" stroke-width="0.5"/>
                    {% endif %}
                  </svg>
                  {{ block.settings.name }}
                </div>
              {% endif %}
              <div class="print-hover-layer">
                <span class="print-hover-btn">View Print</span>
              </div>
            </div>
            <div class="print-info">
              <p class="print-cat">{{ block.settings.category }}</p>
              <p class="print-name">{{ block.settings.name }}</p>
              <p class="print-sub">{{ block.settings.sub }}</p>
            </div>
          </a>

        {% when 'print-limited' %}
          <div class="print-card print-card-wide reveal d2">
            <div class="print-card-img">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1400 | image_tag:
                   sizes: '(min-width: 960px) 50vw, 100vw',
                   widths: '600,900,1200,1600',
                   alt: block.settings.name,
                   loading: 'lazy' }}
              {% else %}
                <div class="print-ph">
                  <svg width="30" height="30" viewBox="0 0 30 30" fill="none">
                    <polygon points="15,1 29,29 1,29" stroke="currentColor" stroke-width="0.75" fill="none"/>
                  </svg>
                  {{ block.settings.name }}
                </div>
              {% endif %}
            </div>
            <div class="print-info">
              <p class="print-cat">{{ block.settings.category }}</p>
              <p class="print-name">{{ block.settings.name }}</p>
              <p class="print-sub">{{ block.settings.sub }}</p>
              <p class="coming-soon-note">{{ block.settings.note }}</p>
              <a class="btn-notify" href="{{ block.settings.cta_link | default: '#' }}">
                {{ block.settings.cta_label | default: 'Notify Me' }}
              </a>
              <div class="print-tag-teal">Limited · 50</div>
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Prints",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Chapter 03 · The Studio" },
    { "type": "text", "id": "title", "label": "Title", "default": "For the love" },
    { "type": "text", "id": "title_em", "label": "Title italic", "default": "of the image." },
    { "type": "textarea", "id": "standfirst", "label": "Standfirst", "default": "The bag and the Schürze are the Workshop — built, tested, numbered. The Studio is what we make when nothing has to be solved. Pictures we couldn't not make, printed on paper that outlives the wall it hangs on. Some things don't need a reason — they're just what the hands do when the day is done." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Enter the Studio →" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "print",
      "name": "Print card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name", "default": "Palm Noir" },
        { "type": "text", "id": "category", "label": "Category", "default": "Open Edition · Studio" },
        { "type": "text", "id": "sub", "label": "Subtext", "default": "A palm at 2 a.m., shot on the way home from a shoot." },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "print-limited",
      "name": "Print card — limited",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name", "default": "Untitled No. 3" },
        { "type": "text", "id": "category", "label": "Category", "default": "Edition of 50 · Signed" },
        { "type": "text", "id": "sub", "label": "Subtext", "default": "Fifty signed, numbered, and gone. One wall per country, roughly." },
        { "type": "text", "id": "note", "label": "Availability note", "default": "Drops this season — first fifty names on the list get first refusal." },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Join the Fifty" },
        { "type": "url", "id": "cta_link", "label": "CTA link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Prints", "category": "Zuuma" }
  ]
}
{% endschema %}

<section id="proof" data-zuuma-section="proof">
  <div class="proof-inner">
    <div class="proof-visual reveal">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag:
           sizes: '(min-width: 960px) 55vw, 100vw',
           widths: '600,900,1200,1600',
           alt: 'Ten kilos, one bag — what fits inside the Zuuma Bag',
           loading: 'lazy' }}
      {% else %}
        <img src="{{ 'bag-03.jpg' | asset_url }}" alt="Ten kilos, one bag" loading="lazy">
      {% endif %}
      <figcaption class="proof-caption">
        <span>{{ section.settings.caption }}</span>
      </figcaption>
    </div>

    <div class="proof-body">
      <p class="eyebrow reveal">{{ section.settings.eyebrow }}</p>
      <h2 class="section-h reveal d1">{{ section.settings.headline }}<em> {{ section.settings.headline_em }}</em></h2>
      <p class="proof-lede reveal d2">{{ section.settings.lede }}</p>

      {% if section.blocks.size > 0 %}
        <ul class="proof-list reveal d3">
          {% for block in section.blocks %}
            <li class="proof-item">
              <span class="proof-item-name">{{ block.settings.name }}</span>
              <span class="proof-item-weight">{{ block.settings.weight }}</span>
            </li>
          {% endfor %}
          <li class="proof-item proof-total">
            <span class="proof-item-name">{{ section.settings.total_label }}</span>
            <span class="proof-item-weight">{{ section.settings.total_weight }}</span>
          </li>
        </ul>
      {% endif %}

      <p class="proof-footnote reveal d4">{{ section.settings.footnote }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Proof — What Fits",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Flat-lay proof image" },
    { "type": "text", "id": "caption", "label": "Image caption", "default": "One bag · 9.8 kg of everyday" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Proof · What fits" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Ten kilos." },
    { "type": "text", "id": "headline_em", "label": "Headline italic", "default": "One bag." },
    { "type": "textarea", "id": "lede", "label": "Lede",
      "default": "We weighed a Tuesday. Laptop, lunch, the yoga class, the grocery run, the bottle of wine for dinner. Nine point eight kilos. The bag carried all of it crossbody. The shoulder didn't complain." },
    { "type": "text", "id": "total_label", "label": "Total label", "default": "Total" },
    { "type": "text", "id": "total_weight", "label": "Total weight", "default": "9.8 kg" },
    { "type": "textarea", "id": "footnote", "label": "Footnote",
      "default": "Tested on a real Tuesday in Kreuzberg. No studio, no staging — just a day." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "name", "label": "Item" },
        { "type": "text", "id": "weight", "label": "Weight" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Proof — What Fits",
      "category": "Zuuma",
      "blocks": [
        { "type": "item", "settings": { "name": "15\" laptop + charger", "weight": "2.1 kg" } },
        { "type": "item", "settings": { "name": "Yoga mat",                "weight": "1.2 kg" } },
        { "type": "item", "settings": { "name": "Groceries",               "weight": "2.4 kg" } },
        { "type": "item", "settings": { "name": "Bottle of wine",          "weight": "1.2 kg" } },
        { "type": "item", "settings": { "name": "Water bottle",            "weight": "0.6 kg" } },
        { "type": "item", "settings": { "name": "Hardcover book",          "weight": "0.9 kg" } },
        { "type": "item", "settings": { "name": "Jacket + scarf",          "weight": "0.8 kg" } },
        { "type": "item", "settings": { "name": "Keys, wallet, phone",     "weight": "0.6 kg" } }
      ]
    }
  ]
}
{% endschema %}

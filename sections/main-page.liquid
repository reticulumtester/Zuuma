<section class="page-wrap" data-zuuma-section="page">
  <div class="page-inner">
    <p class="page-eyebrow">{{ page.title }}</p>
    <h1 class="page-title">{{ page.title }}</h1>
    <div class="page-accent" aria-hidden="true"></div>
    <div class="page-rte rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}

<section id="media-statement"
         class="media-statement{% if section.settings.media_image != blank %} has-media{% endif %}"
         data-zuuma-section="media-statement">
  {% if section.settings.media_image != blank %}
    <img class="media-bg"
         src="{{ section.settings.media_image | image_url: width: 2400 }}"
         alt=""
         data-parallax="0.2"
         loading="lazy">
  {% endif %}

  <div class="media-inner">
    {% if section.settings.eyebrow != blank %}
      <p class="media-eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.line != blank %}
      <p class="media-line">
        {{ section.settings.line }}<em>{{ section.settings.line_em }}</em>
      </p>
    {% endif %}

    {% if section.settings.sub != blank %}
      <p class="media-sub">{{ section.settings.sub }}</p>
    {% endif %}
  </div>

  {% if section.settings.caption != blank %}
    <div class="media-caption">{{ section.settings.caption }}</div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Media / chapter break",
  "settings": [
    { "type": "header", "content": "Typography (shown when no image is set)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow",
      "default": "Interlude" },
    { "type": "text", "id": "line", "label": "Line",
      "default": "And a second object —" },
    { "type": "text", "id": "line_em", "label": "Line italic",
      "default": " tied at the waist." },
    { "type": "textarea", "id": "sub", "label": "Subline",
      "default": "The Schürze follows. Same canvas, same hands, closer to the work." },
    { "type": "text", "id": "caption", "label": "Corner caption" },
    { "type": "header", "content": "Optional media (leave blank for typography-only)" },
    { "type": "image_picker", "id": "media_image", "label": "Background image / video still" }
  ],
  "presets": [
    { "name": "Chapter break", "category": "Zuuma" }
  ]
}
{% endschema %}

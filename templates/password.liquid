<section class="password-page">
  <div class="password-inner">
    <p class="eyebrow">{{ shop.name | default: 'Zuuma' }}</p>
    <h1 class="password-title">
      Coming<em>soon.</em>
    </h1>
    <p class="password-copy">
      One bag, every day. Handmade &amp; numbered in Berlin.
    </p>

    {% form 'storefront_password', class: 'password-form' %}
      {% if form.errors %}
        <p class="password-error">{{ form.errors.messages.form }}</p>
      {% endif %}
      <label for="password" class="visually-hidden">
        {{ 'general.password_page.login_form_password_label' | t }}
      </label>
      <input
        type="password"
        name="password"
        id="password"
        placeholder="{{ 'general.password_page.login_form_password_label' | t }}"
        autocomplete="current-password"
      >
      <button type="submit" class="btn-primary">
        {{ 'general.password_page.login_form_submit' | t }}
      </button>
    {% endform %}
  </div>
</section>

<style>
  body.template-password { background: var(--off-white); color: var(--black); }
  .password-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 6rem 2rem;
    text-align: center;
  }
  .password-inner { max-width: 520px; }
  .password-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 9vw, 7rem);
    line-height: 1;
    font-weight: 300;
    margin: 1.5rem 0 1rem;
  }
  .password-title em {
    display: block;
    font-style: italic;
    color: var(--mid);
  }
  .password-copy {
    font-family: 'Outfit', sans-serif;
    color: var(--mid);
    margin-bottom: 2.5rem;
  }
  .password-form {
    display: flex;
    gap: .75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .password-form input[type="password"] {
    padding: .9rem 1.1rem;
    border: 1px solid var(--black);
    background: transparent;
    font-family: 'Outfit', sans-serif;
    font-size: .95rem;
    min-width: 240px;
  }
  .password-error {
    color: #c0392b;
    margin-bottom: 1rem;
    font-family: 'Outfit', sans-serif;
    font-size: .9rem;
  }
</style>

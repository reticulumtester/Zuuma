<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_background }}">
  <link rel="canonical" href="{{ canonical_url }}">

  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Outfit:wght@200;300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --black: {{ settings.color_foreground }};
      --off-white: {{ settings.color_background }};
      --warm-grey: {{ settings.color_warm_grey }};
      --mid: {{ settings.color_mid }};
      --accent: {{ settings.color_accent }};
    }
  </style>

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {% if settings.enable_smooth_scroll %}
    <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js" defer></script>
  {% endif %}
  {% if settings.enable_scrollytelling %}
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
  {% endif %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  {% if settings.enable_scrollytelling %}
    <script src="{{ 'scrollytelling.js' | asset_url }}" defer></script>
  {% endif %}

  {{ content_for_header }}
</head>
<body class="template-{{ template | split: '.' | first }}">
  <a class="skip-link" href="#main-content">{{ 'general.accessibility.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}
</body>
</html>
